# Application Configuration
NEXT_PUBLIC_APP_NAME=TaskForge
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Feature Flags
NEXT_PUBLIC_DEMO_MODE=true

# Analytics (Optional)
# NEXT_PUBLIC_ANALYTICS_ID=your-analytics-id

# Theme Configuration (Optional)
# NEXT_PUBLIC_DISABLE_DARK_MODE=false

# API Configuration (For future backend integration)
# NEXT_PUBLIC_API_URL=http://localhost:3000/api
# API_SECRET_KEY=your-secret-key-here

# Database Configuration (For future database integration)
# DATABASE_URL=postgresql://user:password@localhost:5432/project_manager
# DATABASE_POOL_SIZE=20

# Authentication (For future auth integration)
# NEXTAUTH_URL=http://localhost:3000
# NEXTAUTH_SECRET=your-nextauth-secret
# OAUTH_CLIENT_ID=your-oauth-client-id
# OAUTH_CLIENT_SECRET=your-oauth-client-secret

# Email Configuration (For future email notifications)
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USER=your-email@example.com
# SMTP_PASSWORD=your-password
# EMAIL_FROM=noreply@example.com

# Logging and Monitoring (Optional)
# LOG_LEVEL=info
# SENTRY_DSN=your-sentry-dsn
